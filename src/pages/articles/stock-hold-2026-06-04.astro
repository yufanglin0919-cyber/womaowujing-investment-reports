---
import { SITE_DISCLAIMER } from "../../consts";

const holdings = [
  ["MU", "666.59", "996.00", "+49.42%"],
  ["LITE", "944.28", "945.08", "+0.08%"],
  ["STM", "57.95", "78.36", "+35.22%"],
  ["TER", "382.48", "406.86", "+6.37%"],
  ["DIOD", "116.05", "112.50", "-3.06%"]
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>第 3 期持仓与盈亏记录 - 398的美股策略</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; color: #111827; background: #ffffff; }
      header { border-bottom: 1px solid #e5e7eb; }
      nav { width: min(1040px, calc(100% - 48px)); min-height: 72px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
      nav a { color: #111827; text-decoration: none; }
      .brand { font-size: 20px; font-weight: 800; }
      .links { display: flex; gap: 28px; font-size: 15px; }
      article { width: min(760px, calc(100% - 48px)); margin: 0 auto; padding: 72px 0 112px; }
      .back { display: inline-block; margin-bottom: 38px; color: #1d4ed8; font-weight: 700; text-decoration: none; }
      h1 { margin: 0; font-size: 38px; line-height: 1.35; letter-spacing: 0; }
      .meta { margin: 18px 0 44px; color: #6b7280; font-size: 14px; }
      .summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; padding: 24px 0; border-top: 1px solid #dfe3e8; border-bottom: 1px solid #dfe3e8; }
      .summary span { display: block; margin-bottom: 6px; color: #6b7280; font-size: 13px; }
      .summary strong { font-size: 18px; }
      h2 { margin: 44px 0 16px; font-size: 23px; }
      .table-scroll { overflow-x: auto; }
      table { width: 100%; min-width: 600px; border-collapse: collapse; }
      th, td { padding: 14px 0; border-bottom: 1px solid #e5e7eb; text-align: left; }
      th { color: #6b7280; font-size: 13px; font-weight: 600; }
      th:not(:first-child), td:not(:first-child) { text-align: right; }
      .change { font-weight: 800; }
      .disclaimer { margin-top: 52px; padding-top: 28px; border-top: 1px solid #dfe3e8; color: #6b7280; font-size: 14px; line-height: 1.8; }
      footer { padding: 30px 24px; border-top: 1px solid #e5e7eb; color: #6b7280; text-align: center; font-size: 14px; }
      footer a { color: inherit; }
      @media (max-width: 640px) {
        nav { width: calc(100% - 36px); min-height: 64px; }
        article { width: calc(100% - 36px); padding: 52px 0 80px; }
        h1 { font-size: 31px; }
        .summary { grid-template-columns: 1fr; gap: 18px; }
        table { min-width: 100%; table-layout: fixed; }
        th, td { padding: 12px 4px; font-size: 12px; }
        th:first-child, td:first-child { width: 18%; }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>
    </header>

    <article>
      <a class="back" href="/holdings/">← 返回历史持仓与盈亏</a>
      <h1>第 3 期持仓与盈亏记录</h1>
      <p class="meta">已平仓 · 已完整公开</p>

      <section class="summary">
        <div><span>持仓期间</span><strong>2026-05-06 → 2026-06-04</strong></div>
        <div><span>平仓日期</span><strong>2026-06-04</strong></div>
        <div><span>等权组合收益率</span><strong>+17.61%</strong></div>
      </section>

      <h2>完整持仓</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr><th>股票</th><th>买入收盘价</th><th>平仓收盘价</th><th>个股涨跌幅</th></tr>
          </thead>
          <tbody>
            {holdings.map(([stock, openPrice, closePrice, returnRate]) => (
              <tr>
                <td>{stock}</td>
                <td>{openPrice}</td>
                <td>{closePrice}</td>
                <td class="change">{returnRate}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="disclaimer">{SITE_DISCLAIMER}</div>
    </article>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>
  </body>
</html>
