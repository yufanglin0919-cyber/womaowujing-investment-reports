---
const records = [
  {
    period: "第 3 期",
    periodRange: "2026-05-06 → 2026-06-04",
    closeDate: "2026-06-04",
    status: "已完整公开",
    holdings: "MU、LITE、STM、TER、DIOD",
    returnRate: "+17.61%",
    link: "/articles/stock-hold-2026-06-04/"
  },
  {
    period: "第 2 期",
    periodRange: "2026-04-08 → 2026-05-05",
    closeDate: "2026-05-05",
    status: "已完整公开",
    holdings: "PWR、STX、LITE、CIEN、COHR",
    returnRate: "+25.93%",
    link: "/articles/stock-hold-2026-05-05/"
  },
  {
    period: "第 1 期",
    periodRange: "2026-03-10 → 2026-04-07",
    closeDate: "2026-04-07",
    status: "已完整公开",
    holdings: "CIEN、GEV、HII、ONTO、MU",
    returnRate: "+8.89%",
    link: "/articles/stock-hold-2026-04-07/"
  }
];

const sortedRecords = [...records].sort((a, b) =>
  b.closeDate.localeCompare(a.closeDate)
);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>历史持仓盈亏 - 398的美股策略</title>
    <meta name="description" content="398的美股策略历史持仓、换仓日期和阶段盈亏记录。" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; color: #111827; background: #ffffff; }
      header { border-bottom: 1px solid #e5e7eb; }
      nav { width: min(1040px, calc(100% - 48px)); min-height: 72px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
      nav a { color: #111827; text-decoration: none; }
      .brand { font-size: 20px; font-weight: 800; }
      .links { display: flex; gap: 28px; font-size: 15px; }
      main { width: min(960px, calc(100% - 48px)); margin: 0 auto; padding: 80px 0 112px; }
      h1 { margin: 0 0 14px; font-size: 38px; letter-spacing: 0; }
      .intro { margin: 0 0 56px; max-width: 720px; color: #5b6470; line-height: 1.8; }
      .records { border-top: 1px solid #dfe3e8; }
      .record { padding: 32px 0; border-bottom: 1px solid #dfe3e8; }
      .record-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 24px; }
      .record h2 { margin: 0; font-size: 24px; }
      .status { color: #1d4ed8; font-size: 14px; font-weight: 700; }
      dl { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px 32px; margin: 0; }
      dt { margin-bottom: 6px; color: #6b7280; font-size: 13px; }
      dd { margin: 0; color: #1f2937; line-height: 1.65; }
      .return { font-weight: 800; }
      .record-link { display: inline-block; margin-top: 24px; color: #1d4ed8; font-weight: 700; text-decoration: none; }
      .record-link:hover { text-decoration: underline; text-underline-offset: 4px; }
      .pagination { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 42px; }
      .pagination button { display: grid; width: 40px; height: 40px; padding: 0; place-items: center; border: 1px solid #d7dde5; border-radius: 8px; background: #ffffff; color: #344054; font: inherit; font-weight: 700; cursor: pointer; }
      .pagination button:hover:not(:disabled):not([aria-current="page"]) { border-color: #9db8f5; color: #1d4ed8; }
      .pagination button[aria-current="page"] { border-color: #1d4ed8; background: #1d4ed8; color: #ffffff; }
      .pagination button:disabled { cursor: default; opacity: 0.4; }
      footer { padding: 30px 24px; border-top: 1px solid #e5e7eb; color: #6b7280; text-align: center; font-size: 14px; }
      footer a { color: inherit; }
      @media (max-width: 700px) {
        nav { width: calc(100% - 36px); min-height: 64px; }
        main { width: calc(100% - 36px); padding: 56px 0 80px; }
        h1 { font-size: 32px; }
        .intro { margin-bottom: 36px; }
        dl { grid-template-columns: 1fr; gap: 18px; }
        .record-head { align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>
    </header>

    <main>
      <h1>历史持仓盈亏</h1>
      <p class="intro">展示每期持仓区间、完整持仓与等权组合收益率。</p>

      <section class="records" aria-label="历史持仓记录">
        {sortedRecords.map((record, index) => (
          <article class="record" data-list-item data-index={index}>
            <div class="record-head">
              <h2>{record.period}</h2>
              <span class="status">{record.status}</span>
            </div>
            <dl>
              <div>
                <dt>持仓期间</dt>
                <dd>{record.periodRange}</dd>
              </div>
              <div>
                <dt>平仓日期</dt>
                <dd>{record.closeDate}</dd>
              </div>
              <div>
                <dt>持仓股票</dt>
                <dd>{record.holdings}</dd>
              </div>
              <div>
                <dt>等权组合收益率</dt>
                <dd class="return">{record.returnRate}</dd>
              </div>
            </dl>
            {record.link && <a class="record-link" href={record.link}>查看完整记录 →</a>}
          </article>
        ))}
      </section>

      <nav
        class="pagination"
        aria-label="历史持仓分页"
        data-pagination
        data-page-size="5"
      ></nav>
    </main>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>

    <script>
      const list = document.querySelector(".records");
      const pagination = document.querySelector("[data-pagination]");
      const items = Array.from(document.querySelectorAll("[data-list-item]"));
      const pageSize = Number(pagination?.getAttribute("data-page-size")) || 5;
      const pageCount = Math.max(1, Math.ceil(items.length / pageSize));

      function readPage() {
        const page = Number(new URLSearchParams(window.location.search).get("page"));
        return Number.isInteger(page) && page >= 1 && page <= pageCount ? page : 1;
      }

      function createButton(label, page, options = {}) {
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = label;
        button.setAttribute("aria-label", options.ariaLabel ?? `第 ${page} 页`);

        if (options.current) {
          button.setAttribute("aria-current", "page");
        }
        if (options.disabled) {
          button.disabled = true;
        }

        button.addEventListener("click", () => showPage(page, true));
        return button;
      }

      function showPage(page, updateUrl = false) {
        const currentPage = Math.min(Math.max(page, 1), pageCount);
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;

        items.forEach((item, index) => {
          if (item instanceof HTMLElement) {
            item.hidden = index < start || index >= end;
          }
        });

        if (pagination instanceof HTMLElement) {
          pagination.replaceChildren(
            createButton("←", currentPage - 1, {
              ariaLabel: "上一页",
              disabled: currentPage === 1
            }),
            ...Array.from({ length: pageCount }, (_, index) =>
              createButton(String(index + 1), index + 1, {
                current: index + 1 === currentPage
              })
            ),
            createButton("→", currentPage + 1, {
              ariaLabel: "下一页",
              disabled: currentPage === pageCount
            })
          );
        }

        if (updateUrl) {
          const url = new URL(window.location.href);
          if (currentPage === 1) {
            url.searchParams.delete("page");
          } else {
            url.searchParams.set("page", String(currentPage));
          }
          window.history.pushState({ page: currentPage }, "", url);
          list?.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      window.addEventListener("popstate", () => showPage(readPage()));
      showPage(readPage());
    </script>
  </body>
</html>
