---
const records = [
  {
    period: "第 3 期",
    openDate: "待更新",
    closeDate: "未平仓",
    status: "部分公开",
    publicStocks: "股票 1（待更新）、股票 2（待更新）",
    fullHoldings: "其余持仓将在平仓后公开",
    returnRate: "平仓后公开",
    link: null
  },
  {
    period: "第 2 期",
    openDate: "2026-04-17",
    closeDate: "2026-05-14",
    status: "已完整公开",
    publicStocks: "DOCN、NXT",
    fullHoldings: "DOCN、NXT、AKAM、LMT、NEE",
    returnRate: "+33.48%",
    link: "/articles/stock_hold_2026-05-14/"
  },
  {
    period: "第 1 期",
    openDate: "2026-03-19",
    closeDate: "2026-04-16",
    status: "已完整公开",
    publicStocks: "ICHR、UCTT",
    fullHoldings: "ICHR、UCTT、FORM、COHR、TER",
    returnRate: "+24.18%",
    link: "/articles/stock_hold_2026-04-16/"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>历史持仓与盈亏 - 398的美股策略</title>
    <meta name="description" content="398的美股策略历史持仓、换仓日期和阶段盈亏记录。" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; color: #111827; background: #ffffff; }
      header { border-bottom: 1px solid #e5e7eb; }
      nav { width: min(1040px, calc(100% - 48px)); min-height: 72px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
      nav a { color: #111827; text-decoration: none; }
      .brand { font-size: 20px; font-weight: 800; }
      .links { display: flex; gap: 28px; font-size: 15px; }
      main { width: min(960px, calc(100% - 48px)); margin: 0 auto; padding: 80px 0 112px; }
      h1 { margin: 0 0 14px; font-size: 38px; letter-spacing: 0; }
      .intro { margin: 0 0 56px; max-width: 720px; color: #5b6470; line-height: 1.8; }
      .records { border-top: 1px solid #dfe3e8; }
      .record { padding: 32px 0; border-bottom: 1px solid #dfe3e8; }
      .record-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 24px; }
      .record h2 { margin: 0; font-size: 24px; }
      .status { color: #1d4ed8; font-size: 14px; font-weight: 700; }
      dl { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px 32px; margin: 0; }
      dt { margin-bottom: 6px; color: #6b7280; font-size: 13px; }
      dd { margin: 0; color: #1f2937; line-height: 1.65; }
      .return { font-weight: 800; }
      .record-link { display: inline-block; margin-top: 24px; color: #1d4ed8; font-weight: 700; text-decoration: none; }
      .record-link:hover { text-decoration: underline; text-underline-offset: 4px; }
      footer { padding: 30px 24px; border-top: 1px solid #e5e7eb; color: #6b7280; text-align: center; font-size: 14px; }
      footer a { color: inherit; }
      @media (max-width: 700px) {
        nav { width: calc(100% - 36px); min-height: 64px; }
        main { width: calc(100% - 36px); padding: 56px 0 80px; }
        h1 { font-size: 32px; }
        .intro { margin-bottom: 36px; }
        dl { grid-template-columns: 1fr; gap: 18px; }
        .record-head { align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>
    </header>

    <main>
      <h1>历史持仓与盈亏</h1>
      <p class="intro">未平仓记录仅公开前两个股票，完整持仓与阶段收益在平仓后公开。</p>

      <section class="records" aria-label="历史持仓记录">
        {records.map((record) => (
          <article class="record">
            <div class="record-head">
              <h2>{record.period}</h2>
              <span class="status">{record.status}</span>
            </div>
            <dl>
              <div>
                <dt>买入 / 换仓日期</dt>
                <dd>{record.openDate}</dd>
              </div>
              <div>
                <dt>平仓日期</dt>
                <dd>{record.closeDate}</dd>
              </div>
              <div>
                <dt>当前公开股票</dt>
                <dd>{record.publicStocks}</dd>
              </div>
              <div>
                <dt>完整持仓</dt>
                <dd>{record.fullHoldings}</dd>
              </div>
              <div>
                <dt>阶段收益率</dt>
                <dd class="return">{record.returnRate}</dd>
              </div>
            </dl>
            {record.link && <a class="record-link" href={record.link}>查看完整记录 →</a>}
          </article>
        ))}
      </section>
    </main>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>
  </body>
</html>
