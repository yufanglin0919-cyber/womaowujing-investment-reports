---
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const entries = [
  {
    title: "研报与观点",
    desc: "发布我的美股投资报告、市场观点和阶段性复盘。",
    link: "/reports/"
  },
  {
    title: "历史持仓与盈亏",
    desc: "记录历史持仓、换仓日期和阶段盈亏表现。",
    link: "/holdings/"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      :root {
        color-scheme: light;
        font-family: "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
        color: #111827;
        background: #f5f7fb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: #f5f7fb;
      }

      a {
        color: inherit;
      }

      header {
        min-height: 480px;
        padding: 32px clamp(24px, 8vw, 128px) 64px;
        color: #ffffff;
        background-image:
          linear-gradient(rgba(9, 16, 29, 0.68), rgba(9, 16, 29, 0.74)),
          url("/images/hero-bg.jpg");
        background-size: cover;
        background-position: center;
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand,
      nav a {
        color: #ffffff;
        text-decoration: none;
      }

      .brand {
        font-size: 20px;
        font-weight: 800;
      }

      .nav-links {
        display: flex;
        gap: 28px;
      }

      nav a {
        font-size: 15px;
        font-weight: 700;
      }

      nav a:hover {
        text-decoration: underline;
        text-underline-offset: 5px;
      }

      .hero {
        max-width: 780px;
        margin-top: 116px;
      }

      h1 {
        margin: 0;
        font-size: clamp(40px, 5.4vw, 62px);
        line-height: 1.16;
        font-weight: 800;
        letter-spacing: 0;
      }

      .hero p {
        margin: 24px 0 0;
        max-width: 620px;
        color: rgba(255, 255, 255, 0.88);
        font-size: 19px;
        line-height: 1.7;
      }

      main {
        width: min(1040px, calc(100% - 48px));
        margin: 0 auto;
        padding: 56px 0 76px;
      }

      .entries {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .entry {
        display: flex;
        min-height: 240px;
        padding: 34px;
        flex-direction: column;
        align-items: flex-start;
        border: 1px solid rgba(203, 213, 225, 0.58);
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.07);
        text-decoration: none;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease;
      }

      .entry h2 {
        margin: 0 0 16px;
        color: #182230;
        font-size: 23px;
        line-height: 1.4;
        font-weight: 700;
      }

      .entry p {
        margin: 0;
        color: #5d6673;
        font-size: 16px;
        line-height: 1.85;
      }

      .entry span {
        display: inline-block;
        margin-top: auto;
        padding-top: 30px;
        color: #1d4ed8;
        font-size: 15px;
        font-weight: 600;
      }

      .entry:hover {
        transform: translateY(-4px);
        border-color: rgba(147, 180, 255, 0.7);
        box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
      }

      .entry:hover span {
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .subscribe {
        max-width: 780px;
        margin: 48px auto 0;
        padding: 42px;
        border: 1px solid rgba(203, 213, 225, 0.58);
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.07);
        text-align: center;
      }

      .subscribe h2 {
        margin: 0 0 14px;
        font-size: 30px;
      }

      .subscribe p {
        margin: 0 0 28px;
        color: #5d6673;
        line-height: 1.75;
      }

      .subscribe-form {
        display: flex;
        gap: 10px;
      }

      .subscribe-form input {
        flex: 1;
        min-width: 0;
        height: 48px;
        padding: 0 15px;
        border: 1px solid #cfd5dc;
        border-radius: 10px;
        font: inherit;
        color: #111827;
        background: #ffffff;
      }

      .subscribe-form input:focus {
        outline: 2px solid #93b4ff;
        outline-offset: 1px;
        border-color: #2563eb;
      }

      .subscribe-form button {
        height: 48px;
        padding: 0 24px;
        border: 0;
        border-radius: 10px;
        background: #1d4ed8;
        color: #ffffff;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .subscribe-form button:hover {
        background: #1e40af;
      }

      .subscribe-form button:disabled {
        cursor: wait;
        opacity: 0.72;
      }

      .subscribe-message {
        min-height: 24px;
        margin: 16px 0 0;
        color: #5d6673;
        font-size: 14px;
        line-height: 1.6;
      }

      .subscribe-message[data-state="success"] {
        color: #047857;
      }

      .subscribe-message[data-state="error"] {
        color: #b42318;
      }

      footer {
        padding: 30px 24px;
        border-top: 1px solid #e2e8f0;
        background: #ffffff;
        color: #6b7280;
        text-align: center;
        font-size: 14px;
      }

      footer a {
        color: inherit;
      }

      @media (max-width: 760px) {
        header {
          min-height: 420px;
          padding: 24px;
        }

        .brand {
          max-width: 180px;
        }

        .nav-links {
          gap: 18px;
        }

        .hero {
          margin-top: 92px;
        }

        h1 {
          font-size: 40px;
        }

        .hero p {
          font-size: 17px;
        }

        main {
          width: min(100% - 36px, 1040px);
          padding: 40px 0 56px;
        }

        .entries {
          grid-template-columns: 1fr;
          gap: 18px;
        }

        .entry {
          min-height: 0;
          padding: 28px;
        }

        .entry span {
          margin-top: 0;
          padding-top: 24px;
        }

        .subscribe {
          margin-top: 32px;
          padding: 32px 24px;
        }

        .subscribe-form {
          display: block;
        }

        .subscribe-form input,
        .subscribe-form button {
          width: 100%;
        }

        .subscribe-form button {
          margin-top: 10px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>

      <section class="hero">
        <h1>398的美股策略</h1>
        <p>长期复利，价值投资</p>
      </section>
    </header>

    <main>
      <section class="entries" aria-label="网站主要内容">
        {entries.map((entry) => (
          <a class="entry" href={entry.link}>
            <h2>{entry.title}</h2>
            <p>{entry.desc}</p>
            <span>查看内容 →</span>
          </a>
        ))}
      </section>

      <section id="subscribe" class="subscribe">
        <h2>订阅更新</h2>
        <p>订阅更新，获取最新研报与持仓复盘提醒。</p>
        <form class="subscribe-form" novalidate>
          <input
            type="email"
            name="email"
            id="subscribe-email"
            placeholder="请输入你的邮箱"
            aria-label="请输入你的邮箱"
            required
          />
          <button type="submit">订阅</button>
        </form>
        <div
          class="subscribe-message"
          role="status"
          aria-live="polite"
        ></div>
      </section>
    </main>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>

    <script>
      const form = document.querySelector(".subscribe-form");
      const input = document.querySelector("#subscribe-email");
      const button = form?.querySelector("button");
      const message = document.querySelector(".subscribe-message");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!(input instanceof HTMLInputElement) ||
            !(button instanceof HTMLButtonElement) ||
            !(message instanceof HTMLElement)) {
          return;
        }

        button.disabled = true;
        button.textContent = "提交中...";
        message.textContent = "";
        message.dataset.state = "";

        try {
          const response = await fetch("/api/subscribe", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              email: input.value
            })
          });

          const result = await response.json();
          message.textContent = result.message ?? "订阅失败，请稍后再试。";
          message.dataset.state = result.success ? "success" : "error";

          if (result.success) {
            input.value = "";
          }
        } catch {
          message.textContent = "订阅失败，请稍后再试。";
          message.dataset.state = "error";
        } finally {
          button.disabled = false;
          button.textContent = "订阅";
        }
      });
    </script>
  </body>
</html>
