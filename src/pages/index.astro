---
import { SITE_DESCRIPTION, SITE_DISCLAIMER, SITE_TITLE } from "../consts";

const modules = [
  {
    title: "我研究什么",
    category: "研究范围",
    desc: "长期跟踪 AI、半导体、软件、云计算、数据中心，以及具备成长属性的美股科技公司。",
    link: "/holdings/",
    cta: "查看研究跟踪池"
  },
  {
    title: "报告怎么写",
    category: "报告框架",
    desc: "每篇报告围绕行业逻辑、财务质量、估值位置、风险清单和后续跟踪指标展开，尽量把判断拆成可复盘的证据。",
    link: "/reports/",
    cta: "查看报告列表"
  },
  {
    title: "策略怎么验证",
    category: "策略复盘",
    desc: "用历史组合对比 QQQ、Nasdaq 100 和 SPY，并记录最大回撤、胜率、交易成本等指标，避免只看单次结果。",
    link: "/history/",
    cta: "查看历史复盘"
  },
  {
    title: "免费样本",
    category: "样本入口",
    desc: "先开放 1 到 3 篇报告样式，展示正文结构、风险清单和后续跟踪指标。后续内容增加后会继续分页整理。",
    link: "/reports/#free-samples",
    cta: "查看免费样本报告"
  },
  {
    title: "订阅说明",
    category: "即将开放",
    desc: "订阅功能暂未正式开放。当前可先通过邮件关注免费报告、历史复盘和站点更新，完整规则会在开放前说明。",
    link: "/subscribe/",
    cta: "查看订阅说明"
  }
];

const samples = [
  {
    title: "AI 算力主线仍需结合估值和盈利验证",
    desc: "一篇美股科技主题样本，展示行业逻辑、核心数据表、风险清单和跟踪指标。",
    link: "/articles/us-tech-weekly-2026-05-24/"
  },
  {
    title: "投研报告模板",
    desc: "用于后续新增公司报告，先保留完整结构，数据不足处以待补充展示。",
    link: "/reports/holding-understanding-template/"
  },
  {
    title: "策略历史复盘样本",
    desc: "展示策略收益、基准收益、超额收益、最大回撤、胜率和错误复盘。",
    link: "/articles/stock_hold_2026-05-14/"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
      body {
        margin: 0;
        font-family: Arial, "Microsoft YaHei", sans-serif;
        background: #f5f7fb;
        color: #1f2937;
      }

      header {
        background-image:
          linear-gradient(
            rgba(15, 23, 42, 0.68),
            rgba(15, 23, 42, 0.78)
          ),
          url("/images/hero-bg.jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: white;
        padding: 48px 10% 72px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 70px;
        gap: 24px;
      }

      .logo {
        font-size: 21px;
        font-weight: 800;
        letter-spacing: 0.2px;
      }

      nav a {
        color: white;
        text-decoration: none;
        margin-left: 24px;
        font-weight: 600;
        opacity: 0.92;
      }

      nav a:hover {
        opacity: 1;
        text-decoration: underline;
      }

      .hero {
        max-width: 880px;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 18px;
        color: #bfdbfe;
        font-size: 15px;
        font-weight: 800;
      }

      .site-title {
        font-size: 44px;
        line-height: 1.28;
        font-weight: 900;
        margin-bottom: 20px;
      }

      .subtitle {
        max-width: 780px;
        font-size: 19px;
        line-height: 1.9;
        opacity: 0.95;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
      }

      .button {
        display: inline-block;
        padding: 12px 18px;
        border-radius: 10px;
        background: white;
        color: #1d4ed8;
        font-weight: 800;
        text-decoration: none;
      }

      .button.secondary {
        background: rgba(255, 255, 255, 0.14);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.32);
      }

      .tags {
        margin-top: 26px;
      }

      .tag {
        display: inline-block;
        margin-right: 10px;
        margin-bottom: 10px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
        font-size: 14px;
        font-weight: 600;
      }

      main {
        max-width: 1120px;
        margin: 56px auto;
        padding: 0 24px;
      }

      .intro,
      .subscribe-box,
      .samples,
      .disclaimer {
        background: white;
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 42px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08);
        line-height: 1.9;
      }

      .intro h1,
      .subscribe-box h2,
      .samples h2 {
        font-size: 28px;
        margin-top: 0;
      }

      .intro p,
      .subscribe-box p,
      .samples p {
        color: #4b5563;
      }

      .section-title {
        font-size: 28px;
        margin-bottom: 24px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: 24px;
      }

      .card {
        background: white;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
      }

      .category {
        display: inline-block;
        font-size: 14px;
        color: #1d4ed8;
        font-weight: 800;
        margin-bottom: 10px;
      }

      .card h2,
      .sample-card h3 {
        font-size: 24px;
        line-height: 1.45;
        margin: 8px 0 10px;
      }

      .card p,
      .sample-card p {
        line-height: 1.8;
        color: #4b5563;
      }

      .card-link,
      .sample-card a {
        display: inline-block;
        margin-top: 18px;
        color: #1d4ed8;
        font-weight: 800;
        text-decoration: none;
      }

      .card-link:hover,
      .sample-card a:hover {
        text-decoration: underline;
      }

      .samples {
        margin-top: 54px;
      }

      .sample-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 18px;
        margin-top: 20px;
      }

      .sample-card {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 22px;
        background: #f8fafc;
      }

      .subscribe-box {
        margin-top: 54px;
      }

      .subscribe-form {
        display: flex;
        gap: 12px;
      }

      .subscribe-form input[type="email"] {
        flex: 1;
        min-width: 0;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        color: #1f2937;
        font-size: 16px;
      }

      .subscribe-form button {
        padding: 12px 18px;
        border: none;
        border-radius: 10px;
        background: #2563eb;
        color: white;
        cursor: pointer;
        font-weight: 800;
      }

      .subscribe-form button:hover {
        background: #1d4ed8;
      }

      .subscribe-form button:disabled {
        background: #94a3b8;
        cursor: not-allowed;
      }

      .disclaimer {
        background: #eef2ff;
        border-left: 5px solid #2563eb;
        color: #374151;
      }

      footer {
        text-align: center;
        color: #6b7280;
        padding: 42px 20px;
        font-size: 14px;
      }

      @media (max-width: 700px) {
        header {
          padding: 34px 24px 56px;
        }

        nav {
          display: block;
          margin-bottom: 52px;
        }

        nav div:last-child {
          margin-top: 18px;
        }

        nav a {
          display: inline-block;
          margin-left: 0;
          margin-right: 18px;
          margin-bottom: 8px;
        }

        .site-title {
          font-size: 34px;
        }

        .subtitle {
          font-size: 17px;
        }

        .button {
          width: 100%;
          box-sizing: border-box;
          text-align: center;
        }

        .subscribe-form {
          display: block;
        }

        .subscribe-form input[type="email"],
        .subscribe-form button {
          width: 100%;
          box-sizing: border-box;
        }

        .subscribe-form button {
          margin-top: 12px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div class="logo">398的美股策略｜美股科技投研</div>
        <div>
          <a href="/">首页</a>
          <a href="/holdings/">研究跟踪池</a>
          <a href="/reports/">投资报告</a>
          <a href="/history/">历史复盘</a>
          <a href="/subscribe/">订阅说明</a>
        </div>
      </nav>

      <section class="hero">
        <div class="eyebrow">398的美股策略｜美股科技投研</div>
        <h1 class="site-title">美股科技投研报告：用数据、财报和策略复盘跟踪高成长公司</h1>
        <div class="subtitle">
          覆盖 AI、半导体、云计算、软件、数据中心等方向。报告用于学习研究、投资框架参考和策略复盘，不提供个性化投资建议。
        </div>

        <div class="hero-actions">
          <a class="button" href="#free-samples">查看免费样本报告</a>
          <a class="button secondary" href="/history/">查看历史复盘</a>
          <a class="button secondary" href="/subscribe/">订阅更新</a>
        </div>

        <div class="tags">
          <span class="tag">AI 与科技成长</span>
          <span class="tag">财报跟踪</span>
          <span class="tag">估值观察</span>
          <span class="tag">策略复盘</span>
        </div>
      </section>
    </header>

    <main>
      <section class="intro">
        <h1>站点定位</h1>
        <p>
          这里把美股科技公司的研究、行业主题观察和策略复盘整理成更固定的报告产品形态。
          内容强调研究框架、数据验证和风险提示，适合用来学习投研方法、节省信息整理时间，并持续观察市场变化。
        </p>
      </section>

      <h2 id="sections" class="section-title">核心模块</h2>

      <section class="grid">
        {modules.map((module) => (
          <article class="card">
            <div class="category">{module.category}</div>
            <h2>{module.title}</h2>
            <p>{module.desc}</p>
            <a class="card-link" href={module.link}>{module.cta} →</a>
          </article>
        ))}
      </section>

      <section id="free-samples" class="samples">
        <h2>免费样本</h2>
        <p>
          当前先提供少量样本入口，用于展示报告结构和复盘方式。后续报告数量增加后，会在投资报告栏目继续分页整理。
        </p>
        <div class="sample-grid">
          {samples.map((sample) => (
            <article class="sample-card">
              <h3>{sample.title}</h3>
              <p>{sample.desc}</p>
              <a href={sample.link}>打开样本 →</a>
            </article>
          ))}
        </div>
      </section>

      <section id="subscribe" class="subscribe-box">
        <h2>订阅更新</h2>
        <p>
          订阅功能即将开放，可先关注免费报告、历史复盘和站点更新。正式邮件服务接入后，会单独说明更新频率、内容类型、风险提示和取消规则。
        </p>

        <form class="subscribe-form">
          <input
            type="email"
            name="email"
            id="bd-email"
            placeholder="请输入你的邮箱"
            aria-label="邮箱地址"
          />
          <button type="button" disabled>即将开放</button>
        </form>
      </section>

      <section class="disclaimer">
        <strong>免责声明：</strong>{SITE_DISCLAIMER}
      </section>
    </main>

    <footer>
      © 2026 398的美股策略｜美股科技投研
    </footer>
  </body>
</html>
