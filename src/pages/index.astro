---
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const entries = [
  {
    title: "研报与观点",
    desc: "发布我的美股投资报告、市场观点和阶段性复盘。",
    link: "/reports/"
  },
  {
    title: "历史持仓与盈亏",
    desc: "记录历史持仓、换仓日期和阶段盈亏表现。",
    link: "/holdings/"
  },
  {
    title: "订阅更新",
    desc: "订阅网站更新，获取最新研报、观点和持仓复盘提醒。",
    link: "#subscribe"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      :root {
        color-scheme: light;
        font-family: Arial, "Microsoft YaHei", sans-serif;
        color: #111827;
        background: #ffffff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: #ffffff;
      }

      a {
        color: inherit;
      }

      header {
        min-height: 520px;
        padding: 32px clamp(24px, 8vw, 128px) 72px;
        color: #ffffff;
        background-image:
          linear-gradient(rgba(9, 16, 29, 0.68), rgba(9, 16, 29, 0.74)),
          url("/images/hero-bg.jpg");
        background-size: cover;
        background-position: center;
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand,
      nav a {
        color: #ffffff;
        text-decoration: none;
      }

      .brand {
        font-size: 20px;
        font-weight: 800;
      }

      .nav-links {
        display: flex;
        gap: 28px;
      }

      nav a {
        font-size: 15px;
      }

      nav a:hover {
        text-decoration: underline;
        text-underline-offset: 5px;
      }

      .hero {
        max-width: 780px;
        margin-top: 132px;
      }

      h1 {
        margin: 0;
        font-size: clamp(42px, 6vw, 68px);
        line-height: 1.12;
        font-weight: 800;
        letter-spacing: 0;
      }

      .hero p {
        margin: 24px 0 0;
        max-width: 620px;
        color: rgba(255, 255, 255, 0.88);
        font-size: 19px;
        line-height: 1.7;
      }

      main {
        width: min(1040px, calc(100% - 48px));
        margin: 0 auto;
        padding: 80px 0;
      }

      .entries {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        border-top: 1px solid #dfe3e8;
        border-bottom: 1px solid #dfe3e8;
      }

      .entry {
        min-height: 230px;
        padding: 34px 30px 32px 0;
        text-decoration: none;
      }

      .entry + .entry {
        padding-left: 30px;
        border-left: 1px solid #dfe3e8;
      }

      .entry h2 {
        margin: 0 0 18px;
        font-size: 24px;
        line-height: 1.35;
      }

      .entry p {
        margin: 0;
        color: #5b6470;
        font-size: 16px;
        line-height: 1.8;
      }

      .entry span {
        display: inline-block;
        margin-top: 32px;
        color: #1d4ed8;
        font-size: 15px;
        font-weight: 700;
      }

      .entry:hover span {
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .subscribe {
        max-width: 720px;
        margin: 96px auto 16px;
        text-align: center;
      }

      .subscribe h2 {
        margin: 0 0 14px;
        font-size: 30px;
      }

      .subscribe p {
        margin: 0 0 28px;
        color: #5b6470;
        line-height: 1.7;
      }

      .subscribe-form {
        display: flex;
        gap: 10px;
      }

      .subscribe-form input {
        flex: 1;
        min-width: 0;
        height: 48px;
        padding: 0 15px;
        border: 1px solid #cfd5dc;
        border-radius: 6px;
        font: inherit;
        color: #111827;
        background: #ffffff;
      }

      .subscribe-form input:focus {
        outline: 2px solid #93b4ff;
        outline-offset: 1px;
        border-color: #2563eb;
      }

      .subscribe-form button {
        height: 48px;
        padding: 0 24px;
        border: 0;
        border-radius: 6px;
        background: #1d4ed8;
        color: #ffffff;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .subscribe-form button:hover {
        background: #1e40af;
      }

      footer {
        padding: 30px 24px;
        border-top: 1px solid #e5e7eb;
        color: #6b7280;
        text-align: center;
        font-size: 14px;
      }

      footer a {
        color: inherit;
      }

      @media (max-width: 760px) {
        header {
          min-height: 440px;
          padding: 24px;
        }

        .brand {
          max-width: 180px;
        }

        .nav-links {
          gap: 18px;
        }

        .hero {
          margin-top: 104px;
        }

        h1 {
          font-size: 42px;
        }

        .hero p {
          font-size: 17px;
        }

        main {
          width: min(100% - 36px, 1040px);
          padding: 56px 0;
        }

        .entries {
          display: block;
        }

        .entry,
        .entry + .entry {
          display: block;
          min-height: 0;
          padding: 28px 0;
          border-left: 0;
        }

        .entry + .entry {
          border-top: 1px solid #dfe3e8;
        }

        .entry span {
          margin-top: 20px;
        }

        .subscribe {
          margin-top: 64px;
        }

        .subscribe-form {
          display: block;
        }

        .subscribe-form input,
        .subscribe-form button {
          width: 100%;
        }

        .subscribe-form button {
          margin-top: 10px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>

      <section class="hero">
        <h1>398的美股策略</h1>
        <p>用极简研报记录美股科技投资与持仓复盘</p>
      </section>
    </header>

    <main>
      <section class="entries" aria-label="网站主要内容">
        {entries.map((entry) => (
          <a class="entry" href={entry.link}>
            <h2>{entry.title}</h2>
            <p>{entry.desc}</p>
            <span>查看内容 →</span>
          </a>
        ))}
      </section>

      <section id="subscribe" class="subscribe">
        <h2>订阅更新</h2>
        <p>订阅更新，获取最新研报与持仓复盘提醒。</p>
        <form class="subscribe-form">
          <input
            type="email"
            name="email"
            placeholder="请输入你的邮箱"
            aria-label="请输入你的邮箱"
            required
          />
          <button type="button">订阅</button>
        </form>
      </section>
    </main>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>
  </body>
</html>
