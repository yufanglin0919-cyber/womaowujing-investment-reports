---
const projects = [
  {
    title: "Data Analysis Research Notebook",
    category: "Research Workflow",
    desc: "Organizing datasets, assumptions, and evaluation notes into a clear research process that can be reviewed and improved over time."
  },
  {
    title: "Analytical Evaluation Framework",
    category: "Analytical Modeling",
    desc: "Comparing model outputs with practical metrics, stability checks, and visual summaries without publishing private project details."
  },
  {
    title: "Risk & Resilience Analysis",
    category: "Decision Analysis",
    desc: "Studying downside scenarios, recovery patterns, and robustness questions from a management engineering perspective."
  },
  {
    title: "Python Automation Prototype",
    category: "Automation",
    desc: "Building small Python tools to reduce repetitive analysis work, standardize outputs, and make research workflows easier to maintain."
  },
  {
    title: "Visualization & Reporting Workflow",
    category: "Communication",
    desc: "Turning analysis results into charts, concise summaries, and presentation-ready explanations for non-technical readers."
  }
];

const skills = [
  "Python",
  "Pandas",
  "NumPy",
  "Matplotlib",
  "Data Cleaning",
  "Data Analysis",
  "Decision Modeling",
  "Automation",
  "Data Visualization",
  "Research Writing"
];

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Yufang Lin | Management Engineering & Data Analysis</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
      body {
        margin: 0;
        font-family: Arial, "Microsoft YaHei", sans-serif;
        background: #f5f7fb;
        color: #1f2937;
      }

      header {
        background-image:
          linear-gradient(
            rgba(15, 23, 42, 0.65),
            rgba(15, 23, 42, 0.75)
          ),
          url("/images/hero-bg.jpg");

        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;

        color: white;
        padding: 56px 10% 72px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 72px;
      }

      .logo {
        font-size: 22px;
        font-weight: 800;
        letter-spacing: 1px;
      }

      nav a {
        color: white;
        text-decoration: none;
        margin-left: 28px;
        font-weight: 600;
        opacity: 0.92;
      }

      nav a:hover {
        opacity: 1;
        text-decoration: underline;
      }

      .hero {
        max-width: 820px;
      }

      .site-title {
        font-size: 46px;
        line-height: 1.25;
        font-weight: 900;
        margin-bottom: 20px;
      }

      .subtitle {
        font-size: 19px;
        line-height: 1.9;
        opacity: 0.95;
      }

      .tags {
        margin-top: 26px;
      }

      .tag {
        display: inline-block;
        margin-right: 10px;
        margin-bottom: 10px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
        font-size: 14px;
        font-weight: 600;
      }

      main {
        max-width: 1120px;
        margin: 56px auto;
        padding: 0 24px;
      }

      .intro {
        background: white;
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 42px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08);
        line-height: 1.9;
      }

      .intro h1 {
        font-size: 28px;
        margin-top: 0;
      }

      .intro p {
        color: #4b5563;
      }

      .section-title {
        font-size: 28px;
        margin-bottom: 24px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: 24px;
      }

      .card {
        background: white;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
      }

      .category {
        display: inline-block;
        font-size: 14px;
        color: #1d4ed8;
        font-weight: 800;
        margin-bottom: 10px;
      }

      .card h2 {
        font-size: 22px;
        line-height: 1.45;
        margin: 8px 0 10px;
      }

      .card p {
        line-height: 1.8;
        color: #4b5563;
      }

      .skills-box,
      .subscribe-box {
        margin-top: 54px;
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08);
      }

      .skills-box h2,
      .subscribe-box h2 {
        font-size: 24px;
        margin-top: 0;
        margin-bottom: 10px;
      }

      .skills-box p,
      .subscribe-box p {
        color: #4b5563;
        line-height: 1.8;
        margin-bottom: 20px;
      }

      .skill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .skill-list li {
        padding: 8px 14px;
        border-radius: 999px;
        background: #eef2ff;
        color: #1d4ed8;
        font-size: 14px;
        font-weight: 800;
      }

      .subscribe-form {
        display: flex;
        gap: 12px;
      }

      .subscribe-form input[type="email"] {
        flex: 1;
        min-width: 0;
        padding: 12px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        color: #1f2937;
        font-size: 16px;
      }

      .subscribe-form button {
        padding: 12px 18px;
        border: none;
        border-radius: 10px;
        background: #2563eb;
        color: white;
        cursor: pointer;
        font-weight: 800;
      }

      .subscribe-form button:hover {
        background: #1d4ed8;
      }

      .disclaimer {
        margin-top: 54px;
        background: #eef2ff;
        border-left: 5px solid #2563eb;
        border-radius: 14px;
        padding: 22px 26px;
        line-height: 1.8;
        color: #374151;
      }

      footer {
        text-align: center;
        color: #6b7280;
        padding: 42px 20px;
        font-size: 14px;
      }

      @media (max-width: 700px) {
        header {
          padding: 36px 24px 56px;
        }

        nav {
          display: block;
          margin-bottom: 52px;
        }

        nav div:last-child {
          margin-top: 18px;
        }

        nav a {
          display: inline-block;
          margin-left: 0;
          margin-right: 18px;
          margin-bottom: 8px;
        }

        .site-title {
          font-size: 36px;
        }

        .subscribe-form {
          display: block;
        }

        .subscribe-form input[type="email"],
        .subscribe-form button {
          width: 100%;
          box-sizing: border-box;
        }

        .subscribe-form button {
          margin-top: 12px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div class="logo">Yufang Lin</div>
        <div>
          <a href="/">Home</a>
          <a href="#projects">Projects</a>
          <a href="#skills">Skills</a>
          <a href="#subscribe">Subscribe</a>
          <a href="/about">About</a>
        </div>
      </nav>

      <section class="hero">
        <div class="site-title">
          Management Engineering, Data Analysis, Python Workflows, and Decision Modeling
        </div>
        <div class="subtitle">
          Management Engineering student focused on using data, models, and Python to analyze
          systems, evaluate decisions, and communicate research clearly.
        </div>

        <div class="tags">
          <span class="tag">Management Engineering</span>
          <span class="tag">Data Analysis</span>
          <span class="tag">Python</span>
          <span class="tag">Decision Modeling</span>
        </div>
      </section>
    </header>

    <main>
      <section class="intro">
        <h1>About This Portfolio</h1>
        <p>
          I am building this site as a personal portfolio for management engineering projects,
          data analysis, decision modeling, and Python-based project notes. Some project details
          are intentionally summarized at a high level, so the site can show my working style
          without publishing private methods or sensitive research logic.
        </p>
      </section>

      <h1 id="projects" class="section-title">Projects</h1>

      <section class="grid">
        {projects.map((project) => (
          <article class="card">
            <div class="category">{project.category}</div>
            <h2>{project.title}</h2>
            <p>{project.desc}</p>
          </article>
        ))}
      </section>

      <section id="skills" class="skills-box">
        <h2>Skills</h2>
        <p>
          Tools and research areas I use to turn complex questions into testable analysis.
        </p>
        <ul class="skill-list">
          {skills.map((skill) => (
            <li>{skill}</li>
          ))}
        </ul>
      </section>

      <section id="subscribe" class="subscribe-box">
        <h2>Subscribe</h2>
        <p>
          Get occasional updates when I publish new notes, project summaries, or learning records.
        </p>

        <form
          action="https://buttondown.com/api/emails/embed-subscribe/yufang"
          method="post"
          target="_blank"
          class="subscribe-form"
        >
          <input
            type="email"
            name="email"
            id="bd-email"
            placeholder="Enter your email"
            required
          />
          <input type="hidden" name="embed" value="1" />
          <button type="submit">Subscribe</button>
        </form>
      </section>

      <section class="disclaimer">
        <strong>Note:</strong>
        This portfolio is for personal research, learning, and project documentation only. Project
        descriptions are intentionally high-level and do not publish private methods.
      </section>
    </main>

    <footer>
      (c) 2026 Yufang Lin | Management Engineering & Data Analysis
    </footer>
  </body>
</html>
