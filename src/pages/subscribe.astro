---
import { SITE_DISCLAIMER } from "../consts";

const benefits = ["美股科技公司研究", "行业主题观察", "策略历史复盘", "财报跟踪", "风险提示"];
const fit = ["想系统了解美股科技公司的投资者", "想学习投研框架的人", "想节省信息整理时间的人"];
const notFit = ["想要短线指令的人", "寻求确定性收益承诺的人", "想要直接照做的人"];
const risks = [
  "所有内容仅为研究和学习。",
  "不构成个性化投资建议。",
  "市场有风险，历史表现不代表未来收益。",
  "用户需要独立判断并自行承担风险。"
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>订阅说明 - 398的美股策略｜美股科技投研</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; background: #f5f7fb; color: #1f2937; }
      header { background: linear-gradient(135deg, #0f172a, #1e3a8a); color: white; padding: 28px 10%; }
      nav { display: flex; justify-content: space-between; align-items: center; }
      .logo { font-size: 20px; font-weight: 800; }
      nav a { color: white; text-decoration: none; margin-left: 24px; font-weight: 600; }
      main { max-width: 1040px; margin: 56px auto; padding: 0 24px; }
      .hero, .card, .subscribe-box, .disclaimer { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08); }
      .hero { margin-bottom: 28px; }
      h1 { margin-top: 0; font-size: 34px; }
      h2 { margin-top: 0; font-size: 24px; }
      p, li { color: #4b5563; line-height: 1.8; }
      li { margin-bottom: 8px; }
      .status { display: inline-block; margin-top: 12px; padding: 8px 12px; border-radius: 999px; background: #eef2ff; color: #1d4ed8; font-weight: 800; font-size: 14px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 22px; margin-top: 24px; }
      .card ul { padding-left: 20px; margin-bottom: 0; }
      .subscribe-box { margin-top: 30px; }
      .subscribe-form { display: flex; gap: 12px; }
      .subscribe-form input[type="email"] { flex: 1; min-width: 0; padding: 12px 14px; border: 1px solid #cbd5e1; border-radius: 10px; color: #1f2937; font-size: 16px; }
      .subscribe-form button { padding: 12px 18px; border: none; border-radius: 10px; background: #2563eb; color: white; cursor: pointer; font-weight: 800; }
      .subscribe-form button:hover { background: #1d4ed8; }
      .subscribe-form button:disabled { background: #94a3b8; cursor: not-allowed; }
      .disclaimer { margin-top: 30px; background: #eef2ff; border-left: 5px solid #2563eb; box-shadow: none; color: #374151; }
      footer { text-align: center; color: #6b7280; padding: 42px 20px; font-size: 14px; }
      @media (max-width: 700px) { nav { display: block; } nav div:last-child { margin-top: 16px; } nav a { display: inline-block; margin-left: 0; margin-right: 18px; margin-bottom: 8px; } .subscribe-form { display: block; } .subscribe-form input[type="email"], .subscribe-form button { width: 100%; box-sizing: border-box; } .subscribe-form button { margin-top: 12px; } }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <div class="logo">398的美股策略｜美股科技投研</div>
        <div>
          <a href="/">首页</a>
          <a href="/holdings/">研究跟踪池</a>
          <a href="/reports/">投资报告</a>
          <a href="/history/">历史复盘</a>
          <a href="/subscribe/">订阅说明</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h1>订阅说明</h1>
        <p>
          订阅功能即将开放，可先关注免费报告和历史复盘。正式开放前，会补充更新频率、内容类型、风险提示、取消规则和退款规则。
        </p>
        <span class="status">即将开放</span>
      </section>

      <section class="grid">
        <article class="card">
          <h2>你能获得什么</h2>
          <ul>
            {benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="card">
          <h2>适合谁</h2>
          <ul>
            {fit.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="card">
          <h2>不适合谁</h2>
          <ul>
            {notFit.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="card">
          <h2>风险提示</h2>
          <ul>
            {risks.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </section>

      <section class="subscribe-box">
        <h2>订阅更新</h2>
        <p>正式邮件服务接入后，可以通过这里收到免费报告、历史复盘和站点更新。当前不是付费订阅入口。</p>
        <form class="subscribe-form">
          <input type="email" name="email" placeholder="请输入你的邮箱" aria-label="邮箱地址" />
          <button type="button" disabled>即将开放</button>
        </form>
      </section>

      <section class="disclaimer">
        <strong>免责声明：</strong>{SITE_DISCLAIMER}
      </section>
    </main>

    <footer>© 2026 398的美股策略｜美股科技投研</footer>
  </body>
</html>
