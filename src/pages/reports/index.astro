---
const reports = [
  {
    title: "6月10日美股市场观点：科技主线降温，宏观压力重新抬头",
    date: "2026-06-10",
    type: "市场观点",
    desc: "复盘科技股估值、通胀压力、利率预期与市场风险变化。",
    link: "/articles/us-market-view-2026-06-10/"
  },
  {
    title: "6月10日个股观察：当前持仓与AI科技主线复盘",
    date: "2026-06-10",
    type: "个股观察",
    desc: "观察 MU、FORM、LITE、ARM、AMD、NVDA、AVGO 与 META 的产业逻辑和主要风险。",
    link: "/articles/ai-stock-watch-2026-06-10/"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>研报与观点 - 398的美股策略</title>
    <meta name="description" content="398的美股策略研报与市场观点归档。" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; color: #111827; background: #ffffff; }
      header { border-bottom: 1px solid #e5e7eb; }
      nav { width: min(1040px, calc(100% - 48px)); min-height: 72px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
      nav a { color: #111827; text-decoration: none; }
      .brand { font-size: 20px; font-weight: 800; }
      .links { display: flex; gap: 28px; font-size: 15px; }
      main { width: min(920px, calc(100% - 48px)); margin: 0 auto; padding: 80px 0 112px; }
      h1 { margin: 0 0 14px; font-size: 38px; letter-spacing: 0; }
      .intro { margin: 0 0 56px; color: #5b6470; line-height: 1.8; }
      .report-list { border-top: 1px solid #dfe3e8; }
      .report { display: grid; grid-template-columns: 130px 1fr 24px; gap: 24px; align-items: start; padding: 28px 0; border-bottom: 1px solid #dfe3e8; color: inherit; text-decoration: none; }
      .meta { color: #6b7280; font-size: 14px; line-height: 1.7; }
      .meta span { display: block; }
      .report h2 { margin: 0 0 10px; font-size: 22px; line-height: 1.45; }
      .report p { margin: 0; color: #5b6470; line-height: 1.75; }
      .arrow { color: #1d4ed8; font-size: 20px; }
      .report:hover h2 { color: #1d4ed8; }
      footer { padding: 30px 24px; border-top: 1px solid #e5e7eb; color: #6b7280; text-align: center; font-size: 14px; }
      footer a { color: inherit; }
      @media (max-width: 640px) {
        nav { width: calc(100% - 36px); min-height: 64px; }
        main { width: calc(100% - 36px); padding: 56px 0 80px; }
        h1 { font-size: 32px; }
        .intro { margin-bottom: 36px; }
        .report { grid-template-columns: 1fr 20px; gap: 14px; }
        .meta { grid-column: 1 / -1; display: flex; gap: 12px; }
        .meta span { display: inline; }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="brand" href="/">398的美股策略</a>
        <div class="links">
          <a href="/">首页</a>
          <a href="/disclaimer/">免责声明</a>
        </div>
      </nav>
    </header>

    <main>
      <h1>研报与观点</h1>
      <p class="intro">美股投资报告、市场观点和阶段性复盘。</p>

      <section class="report-list" aria-label="研报与观点列表">
        {reports.map((report) => (
          <a class="report" href={report.link}>
            <div class="meta">
              <span>{report.date}</span>
              <span>{report.type}</span>
            </div>
            <div>
              <h2>{report.title}</h2>
              <p>{report.desc}</p>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </section>
    </main>

    <footer>
      © 2026 398的美股策略 · <a href="/disclaimer/">免责声明</a>
    </footer>
  </body>
</html>
