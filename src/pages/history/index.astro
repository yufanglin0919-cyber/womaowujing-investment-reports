---
const overview = [
  { label: "起始日期", value: "待补充" },
  { label: "累计收益", value: "待核算" },
  { label: "CAGR", value: "待核算" },
  { label: "最大回撤", value: "待补充" },
  { label: "年化波动", value: "待补充" },
  { label: "夏普比率", value: "待补充" },
  { label: "跑赢纳指时间占比", value: "待补充" },
  { label: "样本说明", value: "当前先保留两轮历史样本结构，完整统计口径后续补充。" }
];

const articles = [
  {
    title: "2026-05-14 策略复盘",
    date: "2026-05-14",
    desc: "复盘 2026-04-17 至 2026-05-14 这一轮等权组合表现，包含策略收益、基准对比、最大回撤、胜率和错误复盘。",
    metrics: "策略收益 33.48% ｜ 胜率 4/5 ｜ 基准收益待补充",
    link: "/articles/stock_hold_2026-05-14/"
  },
  {
    title: "2026-04-16 策略复盘",
    date: "2026-04-16",
    desc: "复盘 2026-03-19 至 2026-04-16 这一轮等权组合表现，保留完整指标结构，便于后续横向比较。",
    metrics: "策略收益 24.18% ｜ 胜率 5/5 ｜ 基准收益待补充",
    link: "/articles/stock_hold_2026-04-16/"
  }
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <title>历史复盘 - 398的美股策略｜美股科技投研</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; background: #f5f7fb; color: #1f2937; }
      header { background: linear-gradient(135deg, #0f172a, #1e3a8a); color: white; padding: 28px 10%; }
      nav { display: flex; justify-content: space-between; align-items: center; }
      .logo { font-size: 20px; font-weight: 800; }
      nav a { color: white; text-decoration: none; margin-left: 24px; font-weight: 600; }
      main { max-width: 1040px; margin: 56px auto; padding: 0 24px; }
      .hero, .card, .pagination, .overview { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 8px 26px rgba(15, 23, 42, 0.08); }
      .hero { margin-bottom: 28px; }
      h1 { margin-top: 0; font-size: 34px; }
      h2 { margin-top: 0; font-size: 26px; }
      p { color: #4b5563; line-height: 1.8; }
      .overview { margin-bottom: 28px; }
      .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin-top: 20px; }
      .metric { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 14px; padding: 16px; }
      .metric span { display: block; color: #64748b; font-size: 14px; font-weight: 800; margin-bottom: 8px; }
      .metric strong { display: block; color: #0f172a; font-size: 18px; line-height: 1.45; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 24px; }
      .meta { color: #1d4ed8; font-size: 14px; font-weight: 800; }
      .card h2 { margin: 10px 0; font-size: 22px; line-height: 1.45; }
      .card a { color: #1d4ed8; font-weight: 800; text-decoration: none; }
      .card .metrics { color: #0f172a; font-weight: 800; }
      .pagination { margin-top: 32px; display: flex; justify-content: space-between; align-items: center; gap: 12px; color: #4b5563; }
      .disabled { color: #9ca3af; }
      footer { text-align: center; color: #6b7280; padding: 42px 20px; font-size: 14px; }
      @media (max-width: 700px) { nav { display: block; } nav div:last-child { margin-top: 16px; } nav a { display: inline-block; margin-left: 0; margin-right: 18px; margin-bottom: 8px; } .pagination { display: block; } }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <div class="logo">398的美股策略｜美股科技投研</div>
        <div>
          <a href="/">首页</a>
          <a href="/holdings/">研究跟踪池</a>
          <a href="/reports/">投资报告</a>
          <a href="/history/">历史复盘</a>
          <a href="/subscribe/">订阅说明</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h1>历史复盘</h1>
        <p>
          历史复盘是网站的核心信任资产。这里不只展示结果，也固定记录基准收益、超额收益、最大回撤、胜率、交易成本、当时逻辑和错误复盘。
        </p>
      </section>

      <section class="overview">
        <h2>策略累计表现总览</h2>
        <p>当前先保留完整统计结构，等样本和口径整理完成后再填入正式数据。</p>
        <div class="metric-grid">
          {overview.map((item) => (
            <div class="metric">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </section>

      <section class="grid">
        {articles.map((article) => (
          <article class="card">
            <div class="meta">{article.date}</div>
            <h2>{article.title}</h2>
            <p class="metrics">{article.metrics}</p>
            <p>{article.desc}</p>
            <a href={article.link}>阅读全文 →</a>
          </article>
        ))}
      </section>

      <section class="pagination">
        <span class="disabled">上一页</span>
        <strong>第 1 页 / 共 1 页</strong>
        <span class="disabled">下一页（后续复盘增加后启用）</span>
      </section>
    </main>

    <footer>© 2026 398的美股策略｜美股科技投研</footer>
  </body>
</html>
